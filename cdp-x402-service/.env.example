CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret
CDP_WALLET_SECRET=your-wallet-secret

# Named CDP EVM account used by buyer payments.
CDP_EVM_ACCOUNT_NAME=sign402-mainnet-buyer

# Optional guard: if set, the service refuses to use a different CDP account.
CDP_EVM_ACCOUNT_ADDRESS=0xYourBuyerAddress

# Seller settings for `npm run serve`.
CDP_SELLER_PAY_TO=0xYourReceiverAddress
CDP_X402_SELLER_PRICE=$0.01
CDP_X402_SELLER_ROUTE=/paid/sign402-report
CDP_X402_SELLER_PORT=4021
